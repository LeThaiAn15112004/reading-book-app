{
  "compilerOptions": {
    "paths": {
      "@reading-book/shared": ["../../packages/shared/index.ts"],
      "@reading-book/shared/*": ["../../packages/shared/*"],
      "@reading-book/config": ["../../packages/config/index.ts"],
      "@reading-book/config/*": ["../../packages/config/*"],
      "@reading-book/domain": ["../../packages/domain/index.ts"],
      "@reading-book/domain/*": ["../../packages/domain/*"]
    },
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "electron"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
